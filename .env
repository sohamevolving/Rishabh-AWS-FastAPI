# MySQL connection — points to your already-running MySQL server
# If MySQL is on the same host machine, use host.docker.internal (Mac/Windows)
# or the host's LAN IP (Linux: run `hostname -I` to find it)
MYSQL_HOST=host.docker.internal   # or e.g. 192.168.1.100
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=secret
MYSQL_DATABASE=store_db